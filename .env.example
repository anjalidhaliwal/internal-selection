# ── Supabase ────────────────────────────────────────────────────
# Project URL + keys from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Host gate ───────────────────────────────────────────────────
# Password the presenter types at /host to control the game + export scores
HOST_PASSWORD=change-me

# ── App URL ─────────────────────────────────────────────────────
# Used to build the QR join code. Set to your deployed URL once known.
NEXT_PUBLIC_APP_URL=http://localhost:3000
